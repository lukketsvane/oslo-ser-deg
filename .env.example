# Notion integration token (server-only secret — NEVER commit the real value).
# Create at https://www.notion.so/my-integrations and share the cctv.oslo database with it.
NOTION_TOKEN=

# Data source id for the cctv.oslo database.
# (NOTION_DB_ID is also accepted as an alias.)
NOTION_DATA_SOURCE_ID=452423a6-82c0-4653-a6f8-755cd74e3081

# Optional: server cache TTL in milliseconds (default 7000).
CACHE_TTL_MS=7000
